// services/aiService.js
// Handles the main question-answer pipeline: normalize → rate limit → vector search → OpenAI → persist
import { rateLimitService } from './rateLimitService.js';
import { vectorService } from './vectorService.js';
import { dbService } from './dbService.js';
import { feedbackService } from './feedbackService.js';
import { openai } from '../lib/openai.js';

export const aiService = {
  async processQuestion({ question, userIp }) {
    await rateLimitService.checkIp(userIp);

    const normalized = question.trim().toLowerCase();
    const similar = await vectorService.findSimilar(normalized);
    if (similar) {
      return { ...similar, source: 'vector-cache' };
    }

    const completion = await openai.chat.completions.create({
      model: process.env.OPENAI_MODEL || 'gpt-4o-mini',
      messages: [{ role: 'user', content: normalized }],
    });

    const answer = completion.choices[0].message.content;
    const embedding = await vectorService.createEmbedding(normalized);

    await dbService.saveQA({ question: normalized, answer, embedding, userIp });
    await vectorService.saveEmbedding(normalized, embedding);

    return { answer, source: 'openai' };
  },
};
