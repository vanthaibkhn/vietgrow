// services/aiService.js
// Handles the main question-answer pipeline: normalize → rate limit → vector search → OpenAI → persist

import { rateLimitService } from './rateLimitService.js';
import { vectorService } from './vectorService.js';
import { dbService } from './dbService.js';
import { feedbackService } from './feedbackService.js';
import { openai } from '../lib/openai.js';

export const aiService = {
  async processQuestion({ question, userIp }) {
    const normalized = question?.trim()?.toLowerCase();
    if (!normalized) throw new Error('Câu hỏi không hợp lệ hoặc trống.');

    console.log(`\n[aiService] 🚀 Bắt đầu xử lý câu hỏi từ IP: ${userIp}`);
    console.log(`[aiService] Nội dung: "${normalized}"`);

    try {
      // 1️⃣ Rate limit check
      try {
        await rateLimitService.checkIp(userIp);
        console.log('[aiService] ✅ Rate limit OK');
      } catch (rateErr) {
        if (rateErr.message === 'limit_exceeded') {
          console.warn('[aiService] ⚠️ Vượt quá giới hạn IP:', userIp);
          throw new Error('limit_exceeded');
        }
        throw new Error(`Rate limit error: ${rateErr.message}`);
      }

      // 2️⃣ Vector search (tìm câu tương tự)
      let similar = null;
      try {
        similar = await vectorService.findSimilar(normalized);
      } catch (vecErr) {
        console.warn('[aiService] ⚠️ Lỗi vectorService.findSimilar:', vecErr.message);
      }

      if (similar) {
        console.log('[aiService] 🧠 Tìm thấy câu trả lời tương tự trong vector cache');
        return { ...similar, source: 'vector-cache' };
      }

      // 3️⃣ Gọi OpenAI API
      let answer = null;
      try {
        const completion = await openai.chat.completions.create({
          model: process.env.OPENAI_MODEL || 'gpt-3.5-turbo',
          messages: [{ role: 'user', content: normalized }],
        });
        answer = completion?.choices?.[0]?.message?.content?.trim() || '(Không có phản hồi từ AI)';
        console.log('[aiService] ✅ Nhận phản hồi từ OpenAI');
      } catch (aiErr) {
        console.error('[aiService] ❌ Lỗi khi gọi OpenAI API:', aiErr.message);
        throw new Error('OpenAI API call failed');
      }

      // 4️⃣ Tạo embedding cho câu hỏi
      let embedding = null;
      try {
        embedding = await vectorService.createEmbedding(normalized);
        console.log('[aiService] ✅ Đã tạo embedding');
      } catch (embErr) {
        console.warn('[aiService] ⚠️ Không thể tạo embedding:', embErr.message);
      }

      // 5️⃣ Lưu dữ liệu vào DB / Filestore
      try {
        await dbService.saveQA({ question: normalized, answer, embedding, userIp });
        console.log('[aiService] 💾 Đã lưu QA vào DB / Filestore');
      } catch (dbErr) {
        console.warn('[aiService] ⚠️ Không thể lưu QA vào DB:', dbErr.message);
      }

      // 6️⃣ Lưu embedding riêng cho vector DB (nếu bật)
      try {
        await vectorService.saveEmbedding(normalized, embedding);
        console.log('[aiService] 📦 Đã lưu embedding vào vector DB');
      } catch (saveErr) {
        console.warn('[aiService] ⚠️ Không thể lưu embedding:', saveErr.message);
      }

      // ✅ Trả kết quả thành công
      return { answer, source: 'openai' };
    } catch (err) {
      // Toàn bộ pipeline lỗi
      console.error('[aiService] 💥 Lỗi pipeline tổng thể:', err.message);

      // Lỗi đặc biệt: vượt giới hạn IP
      if (err.message === 'limit_exceeded') {
        throw new Error('limit_exceeded');
      }

      // Các lỗi khác: OpenAI, DB, Vector…
      throw new Error(`Xử lý thất bại: ${err.message}`);
    }
  },
};

